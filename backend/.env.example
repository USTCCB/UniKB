# ====== LLM 配置（至少填一个） ======
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问 DashScope
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认 LLM 提供商：deepseek / qwen / openai
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat

# Embedding（默认使用本地 sentence-transformers，无需 key）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# Rerank
RERANK_MODEL=BAAI/bge-reranker-base

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/unikb.db
# 生产建议 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://unikb:unikb@localhost:5432/unikb

REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIR=./data/chroma

# 鉴权
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 服务
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO

# MCP
MCP_ENABLED=true
MCP_SERVERS_CONFIG=./mcp_servers.json

# 可观测（可选）
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com