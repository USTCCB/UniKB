# ===== App =====
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ===== LLM Provider =====
# 选择: deepseek | qwen | openai
LLM_PROVIDER=deepseek

# 至少填一个, 其它可以留空
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Embedding (统一用 BGE, 离线可换 ollama)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
RERANK_MODEL=BAAI/bge-reranker-base

# ===== Storage =====
# 默认本地 SQLite, 上线换 PostgreSQL
DATABASE_URL=sqlite:///./data/unikb.db
# DATABASE_URL=postgresql+psycopg2://unikb:unikb@postgres:5432/unikb

REDIS_URL=redis://localhost:6379/0

CHROMA_PERSIST_DIR=./data/chroma
FILE_STORAGE_DIR=./data/files

# ===== Auth =====
JWT_SECRET=change-me-in-production-please-use-openssl-rand
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=1440

# ===== MCP =====
MCP_TRANSPORT=stdio
MCP_SERVER_NAME=unikb

# ===== Observability (可选) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com